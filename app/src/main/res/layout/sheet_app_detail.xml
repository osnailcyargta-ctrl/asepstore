<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0E0E11"
    android:paddingBottom="36dp">

    <View android:layout_width="36dp" android:layout_height="4dp"
        android:background="#2A2A2E" android:layout_gravity="center_horizontal" android:layout_marginTop="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/sheet_icon"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1C1C24"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/sheet_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/sheet_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#444444"
                android:textSize="12sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#151518"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/sheet_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#777777"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:id="@+id/sheet_features"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"/>

        <!-- Progress section -->
        <LinearLayout
            android:id="@+id/progress_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Downloading"
                    android:textColor="#555555"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#7777EE"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#7777EE"
                android:progressBackgroundTint="#1E1E28"/>

        </LinearLayout>

        <!-- Action container -->
        <LinearLayout
            android:id="@+id/action_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Install button (shown when not installed) -->
            <TextView
                android:id="@+id/btn_install"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:gravity="center"
                android:text="Install"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:visibility="visible"/>

            <!-- Open button (shown when installed) -->
            <TextView
                android:id="@+id/btn_open"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Open"
                android:textColor="#4CAF50"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#1A2A1A"
                android:visibility="gone"/>

            <!-- Uninstall button (shown when installed) -->
            <TextView
                android:id="@+id/btn_uninstall"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:gravity="center"
                android:text="Uninstall"
                android:textColor="#EF5350"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="#2A1A1A"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginStart="10dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
